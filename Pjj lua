local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if not checkcaller() then
        -- Chặn dứt điểm việc mất tay / thu Blade dựa trên Log misc 53
        if self.Name == "misc" and method == "FireServer" and args[1] == 53 then
            return nil 
        end
        
        if _G.AntiSaberEnabled then
            if self.Name == "saber" and method == "FireServer" then
                return nil 
            end
            if self.Name == "effectPlayerOld" and method == "FireServer" then
                if args[1] and typeof(args[1]) == "Instance" and args[1].Name == "neckBleedEffectEnd" then
                    return nil
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

