local skillMappings = {
    ["H"] = {"hardenedskin", "HardenedSkin"},
    ["C"] = {"saber", "Saber"},
    ["V"] = {"laserbeam", "LaserBeam"},
    -- Phím X đã được gỡ bỏ khỏi chế độ Inf CD
    ["Z"] = {"vinegrab", "VineGrab"}
}

local function fireSkillRemote(letter)
    local remotes = skillMappings[letter]
    if remotes then
        local hitCFrame = LP:GetMouse().Hit
        for _, name in ipairs(remotes) do
            local r = ReplicatedStorage:FindFirstChild(name, true) or ReplicatedStorage:FindFirstChild(name)
            if r and r:IsA("RemoteEvent") then
                pcall(function() r:FireServer(true) end)
                pcall(function() r:FireServer(hitCFrame) end) 
                pcall(function() r:FireServer() end)
            end
        end
    end
end

