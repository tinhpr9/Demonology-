-- BỘ MÁY XỬ LÝ NGẦM: KHÁNG CHÓANG MẠNH MẼ
RunService.Stepped:Connect(function()
    local char = LP.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")

        if flags.antiStun then
            pcall(function()
                -- 1. Xóa ngay lập tức các Script gây hiệu ứng xấu từ Server trả về
                for _, v in pairs(char:GetChildren()) do
                    local n = v.Name:lower()
                    if n:match("timestop") or n:match("slow") or n:match("hide") or n:match("blind") or n:match("disable") then
                        v:Destroy()
                    end
                end

                -- 2. Ép tốc độ chạy và mở khóa di chuyển
                if hrp and hrp.Anchored then hrp.Anchored = false end
                if hum then
                    if hum.WalkSpeed < 16 then hum.WalkSpeed = 16 end
                    if hum.PlatformStand then hum.PlatformStand = false end
                end

                -- 3. Xóa các tảng băng, đá, stun vật lý bám vào người
                for _, obj in pairs(char:GetChildren()) do
                    if obj:IsA("BasePart") and obj ~= hrp then
                        local n = obj.Name:lower()
                        if n:match("ice") or n:match("stun") or n:match("freeze") or n:match("trap") or n:match("bubble") or n:match("rock") then
                            obj:Destroy()
                        end
                    end
                end

                -- 4. Xóa hiệu ứng mù mắt trên màn hình
                local pg = LP:FindFirstChild("PlayerGui")
                if pg then
                    for _, v in pairs(pg:GetChildren()) do
                        local n = v.Name:lower()
                        if n:match("blind") or n:match("hide") or n:match("black") or n:match("flash") then
                            v:Destroy()
                        end
                    end
                end
            end)
        end

        if flags.autoKite and hrp then
            pcall(function()
                local closestThreat = nil
                local minDist = 25 
                for _, v in pairs(Workspace:GetChildren()) do
                    if v ~= char and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") then
                        if not Players:GetPlayerFromCharacter(v) and not v.Name:match("Dummy") then 
                            local enemyHum = v:FindFirstChild("Humanoid")
                            if enemyHum.Health > 0 then 
                                local dist = (hrp.Position - v.HumanoidRootPart.Position).Magnitude
                                if dist < minDist then
                                    minDist = dist
                                    closestThreat = v.HumanoidRootPart
                                end
                            end
                        end
                    end
                end
                
                if closestThreat then
                    local direction = (hrp.Position - closestThreat.Position).Unit
                    local pushBack = Vector3.new(direction.X, 0, direction.Z).Unit * 1.2
                    hrp.CFrame = hrp.CFrame + pushBack
                end
            end)
        end
    end
end)

