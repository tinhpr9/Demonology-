local function GetNearestEnemy()
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local nearest = nil
    local minDistance = 500

    for _, v in pairs(Workspace:GetChildren()) do
        if v:IsA("Model") and v ~= char and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            if v.Humanoid.Health > 0 then
                local dist = (root.Position - v.HumanoidRootPart.Position).Magnitude
                if dist < minDistance then 
                    minDistance = dist
                    nearest = v
                end
            end
        end
    end
    return nearest
end

-- HOOK: Chặn ngay từ cửa các Server Event gây lag và ảo ảnh
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    if not checkcaller() and method == "FireServer" then
        local badOutgoing = {
            "asbestosblind", "receiveheartattack", "drunkeffect", "attackyourself",
            "timerewind", "wouscreen", "cooleffects", "doHitVFX",
            "illusioncreation", "timeerasure", "newepitaph", "woueffect", "wouclone", 
            "charioteffect", "crazytraineffect", "sabbatheffect", "smashingpumpkineffect", 
            "shakescreen", "focuscamera", "goblind", "parasiteevent", "posestunthingie", 
            "removeplayer", "cmd", "oxygenblind", "kcchat", "skinpop", "bubblepop",
            "universepush", "21stepitaph", "21epitaphBeam", "21epitaphBegin", "21epitaphExplosion"
        }
        if table.find(badOutgoing, self.Name) then return nil end
        
        if self.Name == "misc" and (args[1] == 53 or args[1] == 8 or args[1] == 20) then return nil end
        
        if _G.AntiSaberEnabled then
            if self.Name == "effectPlayerOld" and args[1] and typeof(args[1]) == "Instance" and args[1].Name == "neckBleedEffectEnd" then return nil end
        end
        
        if tostring(self.Name) == "hairprojectiles" then
            local nearestEnemy = GetNearestEnemy() 
            if nearestEnemy and nearestEnemy:FindFirstChild("HumanoidRootPart") then
                args[2] = CFrame.new(nearestEnemy.HumanoidRootPart.Position) 
                return oldNamecall(self, unpack(args))
            end
        end
    end
    return oldNamecall(self, ...)
end)

