task.spawn(function()
    local function hookMobileButtons()
        local gui = LP:WaitForChild("PlayerGui", 5)
        if not gui then return end
        
        local function attachEvent(v)
            if v:IsA("GuiButton") and not v:GetAttribute("InfCDHooked") then
