shopTab:Toggle("Bật Hút Vật Phẩm", false, function(v)
    bringItems = v
    task.spawn(function()
        while bringItems and task.wait(0.2) do
            local char = LP.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                for _, item in pairs(Workspace:GetChildren()) do
                    if item:IsA("Tool") then
                        local handle = item:FindFirstChildWhichIsA("BasePart")
                        if handle then handle.CFrame = char.HumanoidRootPart.CFrame end
                    end
                end
            end
        end
    end)
end)

task.spawn(function()
    local playerGui = LP:WaitForChild("PlayerGui")
    playerGui.DescendantAdded:Connect(function(descendant)
        if descendant.Name:lower():match("shutdown") then pcall(function() descendant:Destroy() end) end
    end)
    for _, v in pairs(playerGui:GetDescendants()) do
        if v.Name:lower():match("shutdown") then pcall(function() v:Destroy() end) end
    end
end)
