                                end
                            end
                        end
                        if letter then fireSkillRemote(letter) end
                    end
                end)
            end
        end

        for _, v in pairs(gui:GetDescendants()) do attachEvent(v) end
        gui.DescendantAdded:Connect(attachEvent)
    end
    hookMobileButtons()
end)

